# Required in production: Google AI Studio API key for Gemini.
# Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Optional: override the Gemini model (default: gemini-3.1-flash-lite).
# GEMINI_MODEL=gemini-3.1-flash-lite

# Optional, local development only: set to 1 to use a canned fake model so
# the app runs without any API key.
# FAKE_MODEL=1

# Optional: the frontend defaults to the bundled backend at <origin>/api and
# the assistant id "agent"; only set these to point at a different server.
# NEXT_PUBLIC_API_URL=
# NEXT_PUBLIC_ASSISTANT_ID=agent

# Optional: LangSmith tracing for debugging and monitoring LLM calls.
# Get an API key at https://smith.langchain.com
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=
